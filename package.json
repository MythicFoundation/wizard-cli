{
  "name": "@mythic/wizard-cli",
  "version": "1.0.0",
  "description": "Wizard CLI — AI-powered Solana & Mythic L2 development CLI",
  "type": "module",
  "bin": {
    "mythic": "./dist/cli.js",
    "wizard": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "mythic",
    "cli",
    "ai",
    "blockchain",
    "claude",
    "development"
  ],
  "author": "Mythic Foundation",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "diff": "^7.0.0",
    "glob": "^11.0.0",
    "ignore": "^6.0.2",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.4",
    "marked-terminal": "^7.2.1",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "eslint": "^9.15.0",
    "puppeteer": "^24.39.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
